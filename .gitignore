# Lake build output and fetched dependencies
/.lake/
/lake-packages/
/build/

# Lean toolchain cache (elan); never part of the repo
.elan/

# Python
__pycache__/
*.pyc
.venv/
venv/

# Editor / OS
.vscode/
.idea/
.DS_Store

# Secrets — never commit API keys
.env
*.key
.oai_key

# Generated judge results / run evidence — keep out of generic commits (ARCHITECTURE.md §15).
# The committed *_preview.yaml fixture is the exception.
docs/judge_results/*.yaml
!docs/judge_results/*_preview.yaml
/evidence/
